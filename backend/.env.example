# Backend server
PORT=5000
NODE_ENV=development

# AI providers
# Small and medium book generators use Cerebras.
CEREBRAS_API_KEY=your_cerebras_api_key
# Long book generator uses Gemini.
GEMINI_API_KEY=your_gemini_api_key
# Research-paper generators use Together AI.
TOGETHER_API_KEY=your_together_api_key

# Supabase database/storage
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_BUCKET=documents

# Optional: if your host already has Chromium installed, point Puppeteer to it.
# Examples: /usr/bin/chromium, /usr/bin/google-chrome-stable
CHROME_EXECUTABLE_PATH=
